# App

APP_SECRET=change-me-random-secret
POSTGRES_PASSWORD=change-me-strong-password

# Git provider

GIT_PROVIDER=github
GIT_HOST=https://github.com
GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxx

# OCR / LLM

OCR_LLM_URL=https://api.anthropic.com/v1/messages
OCR_LLM_TOKEN=sk-ant-xxxxxxxxxxxxxxxxx
OCR_LLM_MODEL=claude-opus-4-6
OCR_USE_ANTHROPIC=true
OCR_LLM_AUTH_HEADER=x-api-key

# Admin user

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Slack

SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxx
SLACK_CHANNEL_ID=C0123456789

SLACK_NOTIFY_ON_SUCCESS=true
SLACK_NOTIFY_ON_FAILURE=true
SLACK_NOTIFY_ON_CANCELLED=false